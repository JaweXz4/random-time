<Window x:Class="RandomTimeGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Random Time Generator" Height="500" Width="600"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Grid>
        <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="20">
            <!-- Title -->
            <TextBlock Text="Random Time Generator" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <!-- Minimum Time Section -->
            <GroupBox Header="Minimum Time" Padding="15" Margin="0,0,0,15" Background="#FFFFFF" BorderThickness="1" BorderBrush="#E0E0E0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Hours -->
                    <TextBlock Text="Hours" Grid.Column="0" Margin="0,0,0,5" FontWeight="Bold" Foreground="#555"/>
                    <TextBox Name="MinHours" Grid.Column="0" Grid.Row="1" Height="35" 
                             Text="1" PreviewTextInput="NumberOnly_PreviewTextInput"
                             FontSize="14" Padding="10"
                             BorderThickness="1" BorderBrush="#D0D0D0"
                             Margin="0,0,10,0"/>

                    <!-- Minutes -->
                    <TextBlock Text="Minutes" Grid.Column="1" Margin="0,0,0,5" FontWeight="Bold" Foreground="#555"/>
                    <TextBox Name="MinMinutes" Grid.Column="1" Grid.Row="1" Height="35" 
                             Text="0" PreviewTextInput="NumberOnly_PreviewTextInput"
                             FontSize="14" Padding="10"
                             BorderThickness="1" BorderBrush="#D0D0D0"
                             Margin="5,0,10,0"/>

                    <!-- Seconds -->
                    <TextBlock Text="Seconds" Grid.Column="2" Margin="0,0,0,5" FontWeight="Bold" Foreground="#555"/>
                    <TextBox Name="MinSeconds" Grid.Column="2" Grid.Row="1" Height="35" 
                             Text="0" PreviewTextInput="NumberOnly_PreviewTextInput"
                             FontSize="14" Padding="10"
                             BorderThickness="1" BorderBrush="#D0D0D0"
                             Margin="5,0,0,0"/>
                </Grid>
            </GroupBox>

            <!-- Maximum Time Section -->
            <GroupBox Header="Maximum Time" Padding="15" Margin="0,0,0,15" Background="#FFFFFF" BorderThickness="1" BorderBrush="#E0E0E0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Hours -->
                    <TextBlock Text="Hours" Grid.Column="0" Margin="0,0,0,5" FontWeight="Bold" Foreground="#555"/>
                    <TextBox Name="MaxHours" Grid.Column="0" Grid.Row="1" Height="35" 
                             Text="3" PreviewTextInput="NumberOnly_PreviewTextInput"
                             FontSize="14" Padding="10"
                             BorderThickness="1" BorderBrush="#D0D0D0"
                             Margin="0,0,10,0"/>

                    <!-- Minutes -->
                    <TextBlock Text="Minutes" Grid.Column="1" Margin="0,0,0,5" FontWeight="Bold" Foreground="#555"/>
                    <TextBox Name="MaxMinutes" Grid.Column="1" Grid.Row="1" Height="35" 
                             Text="0" PreviewTextInput="NumberOnly_PreviewTextInput"
                             FontSize="14" Padding="10"
                             BorderThickness="1" BorderBrush="#D0D0D0"
                             Margin="5,0,10,0"/>

                    <!-- Seconds -->
                    <TextBlock Text="Seconds" Grid.Column="2" Margin="0,0,0,5" FontWeight="Bold" Foreground="#555"/>
                    <TextBox Name="MaxSeconds" Grid.Column="2" Grid.Row="1" Height="35" 
                             Text="0" PreviewTextInput="NumberOnly_PreviewTextInput"
                             FontSize="14" Padding="10"
                             BorderThickness="1" BorderBrush="#D0D0D0"
                             Margin="5,0,0,0"/>
                </Grid>
            </GroupBox>

            <!-- Generate Button -->
            <Button Name="GenerateButton" Click="GenerateButton_Click"
                    Height="45" FontSize="16" FontWeight="Bold"
                    Background="#3498DB" Foreground="White"
                    Content="Generate Random Time"
                    Cursor="Hand"
                    Margin="0,0,0,20"/>

            <!-- Result Section -->
            <GroupBox Header="Result" Padding="15" Background="#FFFFFF" BorderThickness="1" BorderBrush="#E0E0E0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Generated Time:" FontSize="14" FontWeight="Bold" Foreground="#555" Margin="0,0,0,10"/>
                    
                    <TextBlock Name="ResultText" Grid.Row="1"
                               Text="—" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#27AE60"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    
                    <Button Name="CopyButton" Grid.Row="2" Click="CopyButton_Click"
                            Height="40" FontSize="14"
                            Background="#27AE60" Foreground="White"
                            Content="Copy to Clipboard"
                            Cursor="Hand"/>
                </Grid>
            </GroupBox>

            <!-- Status Bar -->
            <TextBlock Name="StatusText" Margin="0,20,0,0" Foreground="#7F8C8D" FontSize="12" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
