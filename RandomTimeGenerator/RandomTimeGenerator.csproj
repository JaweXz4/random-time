<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <StartupObject>RandomTimeGenerator.App</StartupObject>
    <Title>Random Time Generator</Title>
    <Version>1.0.0</Version>
    <Authors>JaweXz4</Authors>
    <Description>A Windows application that generates random times between specified min/max values</Description>
    <PackageProjectUrl>https://github.com/JaweXz4/random-time</PackageProjectUrl>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\LICENSE" Pack="true" PackagePath=""/>
  </ItemGroup>

</Project>
